<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Palette</title>

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Arial;
}

body{
  height:100vh;
  overflow:hidden;
}

/* TOP */
.topbar{
  height:70px;
  display:flex;
  justify-content:center;
  align-items:center;
  gap:10px;
  background:#111827;
}

select, button{
  padding:10px 14px;
  border:none;
  border-radius:10px;
  font-size:15px;
}

button{
  background:#6366f1;
  color:white;
  cursor:pointer;
}

/* 🔥 PALETA REAL FULL SCREEN */
#palette{
  display:flex;
  width:100vw;
  height:calc(100vh - 70px);
}

/* 🔥 CLAVE: cada color ocupa todo el espacio */
.card{
  flex:1;
  height:100%;
  display:flex;
  align-items:flex-end;
  justify-content:center;
  transition:0.2s;
}

.card:hover{
  flex:1.3;
}

/* 🔥 HEX NO AFECTA ANCHO */
.hex{
  width:100%;
  text-align:center;
  padding:18px;
  font-size:20px;
  font-weight:bold;
  background:rgba(255,255,255,0.85);
  cursor:pointer;
  user-select:none;
}

#msg{
  position:fixed;
  top:80px;
  left:50%;
  transform:translateX(-50%);
  background:#22c55e;
  color:white;
  padding:10px 15px;
  border-radius:10px;
  opacity:0;
  transition:0.3s;
}

</style>
</head>

<body>

<div class="topbar">
  <select id="type">
    <option value="all">Todos</option>
    <option value="gray">Grises</option>
    <option value="blue">Azules</option>
    <option value="red">Rojos</option>
    <option value="green">Verdes</option>
  </select>

  <button onclick="gen()">Generar</button>
</div>

<div id="msg"></div>
<div id="palette"></div>

<script is:inline>

const palette = document.getElementById("palette");
const msg = document.getElementById("msg");

function r(min,max){
  return Math.floor(Math.random()*(max-min+1))+min;
}

function hex(n){
  return n.toString(16).padStart(2,"0");
}

function color(type){

  let r1,g,b;

  switch(type){
    case "gray":
      r1=g=b=r(40,220);
      break;

    case "blue":
      r1=r(0,80); g=r(80,180); b=r(170,255);
      break;

    case "red":
      r1=r(180,255); g=r(20,80); b=r(20,80);
      break;

    case "green":
      r1=r(20,80); g=r(170,255); b=r(20,80);
      break;

    default:
      r1=r(0,255); g=r(0,255); b=r(0,255);
  }

  return "#" + hex(r1)+hex(g)+hex(b);
}

function copy(t){
  navigator.clipboard.writeText(t);

  msg.style.opacity=1;
  msg.textContent=t+" copiado ✔";

  setTimeout(()=>msg.style.opacity=0,1200);
}

function gen(){

  palette.innerHTML="";

  const type=document.getElementById("type").value;

  for(let i=0;i<5;i++){

    const c=color(type);

    const div=document.createElement("div");
    div.className="card";
    div.style.background=c;

    const hex=document.createElement("div");
    hex.className="hex";
    hex.textContent=c;

    hex.onclick=()=>copy(c);

    div.appendChild(hex);
    palette.appendChild(div);
  }

}

gen();

</script>

</body>
</html>